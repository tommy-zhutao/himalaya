// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(255)
  username     String    @unique @db.VarChar(100)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  avatarUrl    String?   @map("avatar_url") @db.VarChar(500)
  preferences  Json      @default("{}")
  role         String    @default("user") @db.VarChar(50)
  isActive     Boolean   @map("is_active") @default(true)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  lastLoginAt  DateTime? @map("last_login_at")

  favorites    UserFavorite[]

  @@map("users")
}

model NewsSource {
  id            Int        @id @default(autoincrement())
  name          String     @db.VarChar(255)
  type          String     @db.VarChar(50)
  url           String     @unique @db.VarChar(500)
  category      String?    @db.VarChar(100)
  config        Json       @default("{}")
  enabled       Boolean    @default(true)
  lastFetchedAt DateTime?  @map("last_fetched_at")
  fetchCount    Int        @default(0) @map("fetch_count")
  errorCount    Int        @default(0) @map("error_count")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  news          News[]
  fetchLogs     FetchLog[]

  @@map("news_sources")
}

model News {
  id           Int        @id @default(autoincrement())
  sourceId     Int?       @map("source_id")
  title        String     @db.VarChar(500)
  summary      String?
  content      String?
  author       String?    @db.VarChar(255)
  url          String     @unique @db.VarChar(500)
  imageUrl     String?    @map("image_url") @db.VarChar(500)
  category     String?    @db.VarChar(100)
  tags         Json       @default("[]")
  publishedAt  DateTime?  @map("published_at")
  fetchedAt    DateTime   @default(now()) @map("fetched_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  viewCount    Int        @default(0) @map("view_count")
  likeCount    Int        @default(0) @map("like_count")
  shareCount   Int        @default(0) @map("share_count")
  searchVector Unsupported("tsvector")? @map("search_vector")

  // AI Analysis fields
  aiSummary    String?    @map("ai_summary") @db.Text
  keywords     Json       @default("[]") @map("keywords")
  sentiment    String?    @map("sentiment") @db.VarChar(20)
  qualityScore Int?       @map("quality_score")
  analyzedAt   DateTime?  @map("analyzed_at")

  source       NewsSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  favorites    UserFavorite[]

  @@index([publishedAt(sort: Desc)])
  @@index([category])
  @@index([sourceId])
  @@index([tags], type: Gin)
  @@index([viewCount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([sentiment])
  @@index([qualityScore(sort: Desc)])
  @@map("news")
}

model UserFavorite {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  newsId    Int      @map("news_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  news      News     @relation(fields: [newsId], references: [id], onDelete: Cascade)

  @@unique([userId, newsId])
  @@index([userId])
  @@index([newsId])
  @@map("user_favorites")
}

model FetchLog {
  id               Int       @id @default(autoincrement())
  sourceId         Int?      @map("source_id")
  status           String    @db.VarChar(50)
  itemsFetched     Int       @default(0) @map("items_fetched")
  itemsCreated     Int       @default(0) @map("items_created")
  itemsUpdated     Int       @default(0) @map("items_updated")
  errorMessage     String?   @map("error_message")
  startedAt        DateTime  @map("started_at")
  completedAt      DateTime? @map("completed_at")
  durationSeconds  Int?      @map("duration_seconds")
  createdAt        DateTime  @default(now()) @map("created_at")

  source           NewsSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([sourceId])
  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@map("fetch_logs")
}

model DailyStats {
  id           Int      @id @default(autoincrement())
  date         DateTime @unique @db.Date
  totalNews    Int      @default(0) @map("total_news")
  totalFetched Int      @default(0) @map("total_fetched")
  activeUsers  Int      @default(0) @map("active_users")
  pageViews    Int      @default(0) @map("page_views")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([date(sort: Desc)])
  @@map("daily_stats")
}
